{
    "name": "@becklyn/contentful-migration",
    "version": "0.3.0",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 0",
        "format": "eslint . --fix && prettier --write \"**/*.{ts,tsx,json,scss,css}\"",
        "lint": "eslint . && prettier --check \"**/*.{ts,tsx,json,scss,css}\"",
        "build": "npm run clean && swc . -d dist && tsc && chmod +x dist/bin/migrate.js",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run lint && npm run build",
        "preversion": "npm run lint",
        "migrate": "node dist/bin/migrate.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Becklyn-Studios/contentful-migration.git"
    },
    "files": [
        "dist/**/*"
    ],
    "main": "dist/src/index.js",
    "types": "dist/src/index.d.ts",
    "bin": {
        "migrate": "dist/bin/migrate.js"
    },
    "dependencies": {
        "contentful-management": "^12.3.2",
        "contentful-migration": "^5.0.0",
        "dotenv": "^17.4.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0"
    },
    "devDependencies": {
        "@becklyn/eslint": "^2.0.3",
        "@becklyn/prettier": "^2.1.11",
        "@becklyn/tsconfig": "^1.1.3",
        "@swc/cli": "^0.8.1",
        "@swc/core": "^1.15.33",
        "typescript": "^5.9.3"
    },
    "prettier": "@becklyn/prettier"
}
